<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <!-- Register iisnode handler for Express backend entry script in dist/server.js -->
      <add name="iisnode" path="dist/server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- 1. Node Inspector Debugger Exclusion -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^dist/server.js/_inspect" />
        </rule>

        <!-- 2. Rewrite /api requests to Express Backend -->
        <rule name="API Rewrite" stopProcessing="true">
          <match url="^api(/.*)?$" />
          <action type="Rewrite" url="dist/server.js" />
        </rule>

        <!-- 3. Rewrite /health checks to Express Backend -->
        <rule name="Health Rewrite" stopProcessing="true">
          <match url="^health(/.*)?$" />
          <action type="Rewrite" url="dist/server.js" />
        </rule>

        <!-- 4. Rewrite /api-docs (Swagger UI docs) to Express Backend -->
        <rule name="Swagger Rewrite" stopProcessing="true">
          <match url="^api-docs(/.*)?$" />
          <action type="Rewrite" url="dist/server.js" />
        </rule>

        <!-- 5. React Single Page App Routing (IIS static files fallback) -->
        <rule name="React SPA Routing" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <!-- If request is not for a real physical file -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <!-- Do not intercept backend physical subfolders -->
            <add input="{REQUEST_URI}" pattern="^/(node_modules|prisma|src|dist)" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Secure Directory Browsing -->
    <directoryBrowse enabled="false" />
  </system.webServer>
</configuration>
